{
  "name": "opencode-poke",
  "version": "0.1.5",
  "description": "OpenCode TUI plugin to interact with stuck subagents — abort, retry, or send instructions to frozen child sessions",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./tui": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "subagent",
    "stuck",
    "timeout",
    "retry",
    "agent",
    "poke"
  ],
  "author": "Adam Hassan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adamkadaban/opencode-poke.git"
  },
  "bugs": {
    "url": "https://github.com/Adamkadaban/opencode-poke/issues"
  },
  "homepage": "https://github.com/Adamkadaban/opencode-poke#readme",
  "engines": {
    "opencode": ">=1.14.22"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0 <2.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.15.3",
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
